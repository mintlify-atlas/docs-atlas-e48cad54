  "keyFeatures": [
    "Ultra-lightweight: <10MB RAM, <1s cold start on single-core 0.6GHz processors",
    "Single binary deployment across RISC-V, ARM64, and x86_64 architectures",
    "Persistent long-term memory across sessions and reboots",
    "Multi-channel messaging: Slack, Discord, Telegram, WhatsApp, DingTalk, Feishu, LINE, WeCom, QQ",
    "Universal LLM support: OpenAI, Anthropic, Google Gemini, Groq, Ollama, DeepSeek, and more",
    "Built-in tool system: shell execution, filesystem, web search, cron scheduling, I2C/SPI hardware",
    "Model Context Protocol (MCP) integration for external tool servers",
    "Skills marketplace via ClawHub registry",
    "Sandbox security with workspace confinement and command filtering",
    "Multi-agent spawning and sub-agent orchestration"
  ],
  "publicApiSurface": [
    "operator onboard",
    "operator gateway",
    "operator agent -m <message>",
    "operator auth login --provider <provider>",
    "operator auth models",
    "operator skills search <query>",
    "operator skills install <skill>",
    "operator cron list",
    "operator status",
